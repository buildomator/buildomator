{
  "name": "gsd",
  "version": "4.3.0",
  "description": "Buildomator: a structured workflow plugin for Claude Code that adds planning, execution, and verification commands with MCP-backed project state",
  "author": {
    "name": "Jasper Nuyens"
  },
  "homepage": "https://buildomator.com",
  "repository": "https://buildomator.com",
  "license": "MIT",
